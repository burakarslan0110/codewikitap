{
  "name": "codewikitap",
  "version": "0.3.0",
  "description": "Project-aware MCP server that brings Google CodeWiki documentation into coding agents (Claude Code, Cursor, Codex CLI, Gemini CLI, Qwen Code, opencode, Antigravity). Scans your project's manifests, detects which dependencies have CodeWiki coverage, and exposes 7 structured tools with hybrid sparse+dense retrieval, knowledge graph traversal, and always-on citation enforcement.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codewikitap": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.tr.md",
    "LICENSE",
    "assets",
    ".claude-plugin",
    ".mcp.json"
  ],
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "setup-deps": "pnpm install",
    "build": "node ./node_modules/typescript/bin/tsc",
    "dev": "node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "lint": "node ./node_modules/eslint/bin/eslint.js src tests scripts --ext .ts",
    "test": "node ./node_modules/vitest/vitest.mjs run --project unit",
    "test:integration": "node ./node_modules/vitest/vitest.mjs run --project integration",
    "test:all": "node ./node_modules/vitest/vitest.mjs run --project unit --project integration",
    "audit": "node ./node_modules/vitest/vitest.mjs run --project audit",
    "capture-fixtures": "node ./node_modules/tsx/dist/cli.mjs scripts/capture-fixtures.ts",
    "eval": "node ./node_modules/tsx/dist/cli.mjs scripts/eval.ts",
    "verify-publish": "node scripts/verify-publish.mjs",
    "prepublishOnly": "node ./node_modules/typescript/bin/tsc"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codewiki",
    "google-codewiki",
    "documentation",
    "ai-agent",
    "claude-code",
    "cursor",
    "codex",
    "gemini-cli",
    "knowledge-graph",
    "hybrid-retrieval",
    "plugin",
    "claude-plugin",
    "plugin-marketplace"
  ],
  "author": "Burak Arslan <burakarslan0110@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/burakarslan0110/codewikitap#readme",
  "bugs": {
    "url": "https://github.com/burakarslan0110/codewikitap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burakarslan0110/codewikitap.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "chokidar": "^3.6.0",
    "fast-xml-parser": "^5.7.3",
    "jsdom": "^25.0.0",
    "playwright": "^1.51.0",
    "semver": "^7.8.0",
    "sqlite-vec": "^0.1.6",
    "tinyglobby": "^0.2.16",
    "turndown": "^7.2.0",
    "yaml": "^2.8.4",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "@types/semver": "^7.7.1",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "protobufjs",
      "sharp"
    ]
  }
}
